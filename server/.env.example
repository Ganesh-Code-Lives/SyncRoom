# ─────────────────────────────────────────────────────────────────
# SyncRoom Server — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# Your Oracle VM's PUBLIC IP address (required for Mediasoup WebRTC)
# Find it in Oracle Cloud Console → Compute → Instances → your VM
ANNOUNCED_IP=YOUR_ORACLE_VM_PUBLIC_IP

# Node environment
NODE_ENV=production

# Port the server listens on
PORT=3001

# (Optional) Frontend URL for CORS — your Vercel deployment URL
CLIENT_URL=https://syncroom-theta.vercel.app

# TURN Server credentials from metered.ca (for users behind strict NAT)
VITE_TURN_USER=ea1f7df3be57f000d3a26f35
VITE_TURN_PASS=r+1ewjBfglHIWxb7
